{"ast":null,"code":"export default {\n  name: \"AppGrid\",\n  data: function () {\n    return {\n      windows: this.$store.getters.getWindows,\n      gridHeight: \"\"\n    };\n  },\n  methods: {\n    openWindow(windowId) {\n      const payload = {\n        windowState: \"open\",\n        windowID: windowId\n      };\n      this.$store.commit(\"setWindowState\", payload);\n    },\n    openGithub() {\n      window.open(\"https://github.com/DonChiaQE\");\n    }\n  },\n  mounted() {\n    let gridH = this.$store.getters.getFullscreenWindowHeight;\n    this.gridHeight = gridH.substring(0, gridH.length - 2) - 60 + \"px\";\n  }\n};","map":{"version":3,"names":["name","data","windows","$store","getters","getWindows","gridHeight","methods","openWindow","windowId","payload","windowState","windowID","commit","openGithub","window","open","mounted","gridH","getFullscreenWindowHeight","substring","length"],"sources":["src/components/AppGrid.vue"],"sourcesContent":["<template>\n  <nav class=\"grid-container\" :style=\"{ height: gridHeight }\">\n    <li v-for=\"window in windows\" :key=\"window.key\">\n      <button\n        class=\"icon\"\n        v-if=\"window.showInAppGrid != false\"\n        @touchstart=\"openWindow(window.windowId)\"\n        @dblclick=\"openWindow(window.windowId)\"\n      >\n        <img\n          class=\"icon-image\"\n          :src=\"require('../assets/win95Icons/' + window.iconImage)\"\n          :alt=\"window.altText\"\n        />\n        <div class=\"border\">\n          <p class=\"icon-text\">\n            {{ window.displayName }}\n          </p>\n        </div>\n      </button>\n    </li>\n  </nav>\n</template>\n\n<style scoped>\n.icon-text {\n  font-size: 12px;\n  font-weight: 300;\n}\n\n.icon:hover {\n  cursor: pointer;\n}\n</style>\n\n<script>\nexport default {\n  name: \"AppGrid\",\n  data: function () {\n    return {\n      windows: this.$store.getters.getWindows,\n      gridHeight: \"\",\n    };\n  },\n  methods: {\n    openWindow(windowId) {\n      const payload = {\n        windowState: \"open\",\n        windowID: windowId,\n      };\n      this.$store.commit(\"setWindowState\", payload);\n    },\n    openGithub() {\n      window.open(\"https://github.com/DonChiaQE\");\n    },\n  },\n  mounted() {\n    let gridH = this.$store.getters.getFullscreenWindowHeight;\n    this.gridHeight = gridH.substring(0, gridH.length - 2) - 60 + \"px\";\n  },\n};\n</script>\n"],"mappings":"AAoCA;EACAA,IAAA;EACAC,IAAA,WAAAA,CAAA;IACA;MACAC,OAAA,OAAAC,MAAA,CAAAC,OAAA,CAAAC,UAAA;MACAC,UAAA;IACA;EACA;EACAC,OAAA;IACAC,WAAAC,QAAA;MACA,MAAAC,OAAA;QACAC,WAAA;QACAC,QAAA,EAAAH;MACA;MACA,KAAAN,MAAA,CAAAU,MAAA,mBAAAH,OAAA;IACA;IACAI,WAAA;MACAC,MAAA,CAAAC,IAAA;IACA;EACA;EACAC,QAAA;IACA,IAAAC,KAAA,QAAAf,MAAA,CAAAC,OAAA,CAAAe,yBAAA;IACA,KAAAb,UAAA,GAAAY,KAAA,CAAAE,SAAA,IAAAF,KAAA,CAAAG,MAAA;EACA;AACA"},"metadata":{},"sourceType":"module","externalDependencies":[]}